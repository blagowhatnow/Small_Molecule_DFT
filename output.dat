H          9.25330       -0.89130       -0.25660


units bohr
no_reorient
no_com

}

set {
  basis STO-3G
  scf_type df
  pcm true
  pcm_scf_type total
}

pcm = {
   Units = Angstrom
   Medium {
   SolverType = IEFPCM
   Solvent = Water
   }

   Cavity {
   RadiiSet = UFF
   Type = GePol
   Scaling = False
   Area = 0.3
   Mode = Implicit
   }
}

e, wfn = psi4.energy("B3LYP/aug-cc-pVDZ", return_wfn=True, molecule=molecule)

HOMO = wfn.epsilon_a_subset('AO', 'ALL').np[wfn.nalpha()-1]
LUMO = wfn.epsilon_a_subset('AO', 'ALL').np[wfn.nalpha()]

print(HOMO, LUMO, e)


